---
import { ui } from "@/i18n/ui";
import formattedDate from "@/libs/helpers/formattedDate";
import Link from "@/libs/helpers/Link.astro";
import { documentToHtmlString } from "@contentful/rich-text-html-renderer";
import { Image } from "astro:assets";

const local = Astro.currentLocale as "en" | "it";

type Props = {
  item: any;
};

const { item } = Astro.props;
---

<Link
  href={"news&events/" + item.sys.id}
  class="flex w-full flex-col items-start justify-start bg-gradient-to-br from-[#f9fbff] via-white to-[#f6faff] rounded-2xl shadow-[0_1px_2px_rgba(0,0,0,0.04)] hover:shadow-[0_6px_16px_rgba(0,0,0,0.08)] hover:-translate-y-[1.5px] transition-all duration-500 ease-out"
>
  <div
    class="flex aspect-video h-auto w-full items-center justify-center overflow-hidden rounded-t-2xl"
  >
    <Image
      src={item.fields.featuredImage.fields.file.url}
      width={500}
      height={500}
      transition:name={item.fields.featuredImage.fields.file.url}
      alt={item.fields.featuredImage.fields.file.fileName}
      class="h-full w-full overflow-hidden rounded-t-2xl object-cover"
    />
  </div>
  <div class="px-6 py-6">
    <span class="text-vim-red mt-4 text-sm font-bold uppercase">
      {item.fields.type}
    </span>
    <h3 class="text-2xl font-medium">{item.fields.title}</h3>

    <span
      class="mt-2 mb-6 line-clamp-3"
      set:html={documentToHtmlString(item.fields.description)}
    />

    <div
      class="text-vim-blue mt-auto flex items-center justify-between gap-10 text-sm"
    >
      <p class="font-medium">{formattedDate(item.fields.date)}</p>
      <button class="font-bold underline">
        {ui[local].buttons["read-more"]}
      </button>
    </div>
  </div>
</Link>
