---
import { CustomBtn } from "@/ui/buttons";
import main_padding from "@/styles/padding";
import icons from "@/assets/image/dummi/APPROVALS icon.webp";
import { Image } from "astro:assets";
import { ui } from "@/i18n/ui";
import { contentfulClient } from "@/libs/content/contentful/data";
import type { TypeApprovals } from "@/libs/content/contentful/entriesType";
const local = Astro.currentLocale as "en" | "it";

const data = await contentfulClient.getEntries<TypeApprovals>({
  content_type: "approvalsSupplyReferences",
});

const flatData = data.items.flatMap((item) => item.fields.references);
---

<section
  class={`wrapper text-black flex flex-col items-center overflow-hidden relative z-0  gap-6 ${main_padding.y}`}
>
  <h2 class="text-center text-3xl font-medium lg:text-4xl">
    {ui[local].home["supply-references"]}
  </h2>

  <div class="w-full">
    <supply-references-slider class="contents">
      <div class="swiper supply-references-home overflow-hidden">
        <div class="swiper-wrapper">
        {
          flatData.map((item) => (
            <div class="swiper-slide flex !w-max flex-col items-start justify-start rounded-lg px-6 py-6">
              <Image
                src={item.fields.file.url}
                alt={item.fields.file.fileName}
                class="h-[66px] w-auto object-contain"
                height={300}
                width={300}
              />
            </div>
          ))
        }
        </div>
      </div>
    </supply-references-slider>
  </div>

  <script>
    import Swiper from "swiper";
    import { Autoplay, Mousewheel } from "swiper/modules";
    import "swiper/css";

    class SupplyReferencesSlider extends HTMLElement {
      connectedCallback() {
        const swiperEl = this.querySelector(".swiper.supply-references-home");
        if (!swiperEl) return;

        swiperEl.classList.remove("swiper-initialized");

        this.swiper = new Swiper(swiperEl, {
          modules: [Autoplay, Mousewheel],
          mousewheel: {
            forceToAxis: true,
            releaseOnEdges: true,
          },
          spaceBetween: 40,
          slidesPerView: "auto",
          speed: 800,
          loop: true,
          autoplay: {
            delay: 4500,
            disableOnInteraction: false,
          },
        });

        this.handleBeforePreparation = () => {
          if (this.swiper && !this.swiper.destroyed) {
            this.swiper.destroy(true, true);
          }
        };

        document.addEventListener("astro:before-preparation", this.handleBeforePreparation, { once: true });
      }

      disconnectedCallback() {
        if (this.handleBeforePreparation) {
          document.removeEventListener("astro:before-preparation", this.handleBeforePreparation);
        }
        if (this.swiper && !this.swiper.destroyed) {
          this.swiper.destroy(true, true);
        }
      }
    }

    if (!customElements.get("supply-references-slider")) {
      customElements.define("supply-references-slider", SupplyReferencesSlider);
    }
  </script>
</section>
