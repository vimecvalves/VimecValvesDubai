---
import main_padding from "@/styles/padding";
import { Image } from "astro:assets";
import founder from "@/assets/image/home/founder.webp";
import { ui } from "@/i18n/ui";

const local = Astro.currentLocale as "en" | "it";
---

<section
  class={`wrapper text-black py-10 md:grid flex flex-col grid-cols-2 md:gap-20 gap-6 h-max items-center justify-items-center`}
>
  <div class="flex flex-col items-start justify-start gap-4 max-md:order-1">
    <h3 class="text-3xl font-medium max-md:hidden">
      {ui[local].home["our-history"].title}
    </h3>
    <p set:html={ui[local].home["our-history"].description} />
  </div>
  <div>
    <h3 class="text-3xl font-medium md:hidden text-center mb-8">
      {ui[local].home["our-history"].title}
    </h3>

    <Image
      src={founder}
      alt=""
      class="object-contain h-full md:max-h-[400px] object-center w-auto"
    />
  </div>
</section>
