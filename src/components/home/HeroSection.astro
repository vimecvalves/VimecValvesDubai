---
import { Image } from "astro:assets";
import years50 from "@/assets/image/home/50 years.png";
import texture1 from "@/assets/image/home/vales and textures/texture1.webp";
import valve1 from "@/assets/image/home/vales and textures/valve1.webp";

import main_padding from "@/styles/padding";
import { ui } from "@/i18n/ui";
import CustomBtn from "@/ui/CustomBtn.astro";
import type { Asset } from "contentful";

const local = Astro.currentLocale as "en" | "it";

interface Props {
  data: {
    fields: {
      image: Asset;
      texture: Asset;
    };
  }[];
}

const { data } = Astro.props;

let valves = data.map((item) => item.fields.image.fields.file?.url);
let textures = data.map((item) => item.fields.texture.fields.file?.url);
---
{valves.slice(1).map((url) => (
  url && <link rel="preload" as="image" href={`${url}?fm=webp&q=80&w=1000`} />
))}
{textures.slice(1).map((url) => (
  url && <link rel="preload" as="image" href={`${url}?fm=webp&q=80&w=1000`} />
))}

<section
  class={`wrapper lg:min-h-screen text-black flex flex-col items-start justify-center relative z-0 overflow-visible ${main_padding.y}`}
>
  <div class="flex flex-col items-start justify-center lg:max-w-[40vw]">
    <h1
      class="reveal-up mt-28 text-4xl leading-[120%] font-medium lg:mt-52 lg:text-5xl max-w-[18ch]"
    >
      {ui[local].home["hero-section"].title}
    </h1>
    <p class="reveal-up mt-3 text-base lg:mt-4 lg:text-lg">
      {ui[local].home["hero-section"].subtitle}
    </p>
    
    <div class="reveal-up w-full mt-8 lg:mt-12">
      <CustomBtn invert href="products" className="uppercase">
        {ui[local].buttons["view-products"]}
      </CustomBtn>
    </div>

    <Image
      src={years50}
      alt=""
      loading="eager"
      fetchpriority="high"
      class="reveal-up mt-10 h-36 w-auto object-contain max-lg:hidden"
    />
  </div>

  <div
    id="homeHeroImagesContainer"
    class="reveal-up right-0 bottom-[10%] flex h-full w-full items-end max-lg:-translate-x-[20%] lg:absolute lg:w-1/2"
  >
    <Image
      src={textures[0] ? `${textures[0]}?fm=webp&q=80&w=1000` : texture1}
      alt=""
      id="texture"
      width={1000}
      height={1000}
      loading="eager"
      fetchpriority="high"
      class="transition-image absolute bottom-[0px] left-1/2 h-auto w-full -translate-x-[calc(50%-20%)] !overflow-visible object-contain lg:-translate-x-1/2"
    />
    <Image
      src={valves[0] ? `${valves[0]}?fm=webp&q=80&w=1000` : valve1}
      width={1000}
      height={1000}
      alt="Industrial valve preview"
      id="valve"
      loading="eager"
      fetchpriority="high"
      class="animate-jump transition-image z-10 h-auto w-[100%] !overflow-visible object-contain object-center"
    />
  </div>
</section>

<style>
  @keyframes bounce {
    0%,
    100% {
      transform: translateY(-5%);
      animation-timing-function: linear;
    }
    50% {
      transform: none;
      animation-timing-function: linear;
    }
  }
  .animate-jump {
    animation: bounce 3s infinite;
  }

  .transition-image {
    transition: opacity 0.5s ease-in-out;
  }

  .transition-image.fade-out {
    opacity: 0;
  }
</style>

<script is:inline define:vars={{ valves, textures }}>
  let valveIndex = 0;
  let textureIndex = 0;
  const container = document.querySelector("#homeHeroImagesContainer");
  const [textureImg, valveImg] = container?.querySelectorAll([
    "#texture",
    "#valve",
  ]);

  function changeImages() {
    if (valveImg && textureImg) {
      valveImg.classList.add("fade-out");
      textureImg.classList.add("fade-out");

      setTimeout(() => {
        valveImg.src = valves[valveIndex] ? valves[valveIndex] + "?fm=webp&q=80&w=1000" : "";
        textureImg.src = textures[textureIndex] ? textures[textureIndex] + "?fm=webp&q=80&w=1000" : "";
        valveIndex = (valveIndex + 1) % valves.length;
        textureIndex = (textureIndex + 1) % textures.length;
        valveImg.classList.remove("fade-out");
        textureImg.classList.remove("fade-out");
      }, 500);
    }
  }

  function initializeImages() {
    changeImages();
  }

  initializeImages();
  const intervalId = setInterval(changeImages, 8000);

  window.addEventListener("astro:page-before-unload", () => {
    clearInterval(intervalId);
  });
</script>
