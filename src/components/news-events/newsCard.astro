---
import { ui } from "@/i18n/ui";
import formattedDate from "@/libs/helpers/formattedDate";
import Link from "@/libs/helpers/Link.astro";
import { documentToHtmlString } from "@contentful/rich-text-html-renderer";
import { Image } from "astro:assets";

const local = Astro.currentLocale as "en" | "it";

type Props = {
  item: any;
};

import { slugify } from "@/libs/utils/slugify";

const { item } = Astro.props;
// @ts-ignore
const slug = item.fields.slug ?? slugify(item.fields.title);
---

<Link
  href={`news-events/${slug}`}
  class="reveal-up group flex w-full flex-col items-start justify-start bg-gradient-to-br from-[#f9fbff] via-white to-[#f6faff] rounded-2xl shadow-[0_4px_10px_rgba(0,0,0,0.06)] hover:shadow-[0_16px_32px_rgba(0,0,0,0.12)] hover:-translate-y-[6px] transition-all duration-400 ease-out overflow-hidden"
>
  {/* Image with hover zoom */}
  <div class="mx-4 mt-4 aspect-video overflow-hidden rounded-xl">
    <Image
      src={item.fields.featuredImage.fields.file.url}
      width={600}
      height={400}
      alt={item.fields.title || "News post image"}
      decoding="async"
      loading="lazy"
      class="h-full w-full rounded-xl object-cover transition-transform duration-400 ease-out group-hover:scale-105"
    />
  </div>

  <div class="px-6 py-6 flex flex-col flex-grow w-full">
    {/* Badge */}
    <span
      class="inline-block mb-3 self-start rounded px-2 py-1 text-[11px] font-semibold uppercase tracking-wider text-white"
      style="background: #e11d2e; letter-spacing: 0.08em;"
    >
      {item.fields.type}
    </span>

    <h3 class="text-2xl font-medium leading-snug">{item.fields.title}</h3>

    {/* Clamped description */}
    <span
      class="mt-2 mb-6 text-gray-500 text-sm leading-relaxed line-clamp-2"
      set:html={documentToHtmlString(item.fields.description)}
    />

    {/* Footer row */}
    <div class="text-vim-blue mt-auto flex items-center justify-between gap-10 text-sm">
      <p class="font-medium">{formattedDate(item.fields.date)}</p>
      <span class="font-semibold text-vim-blue hover:underline transition-all">
        {ui[local].buttons["read-more"]} →
      </span>
    </div>
  </div>
</Link>

