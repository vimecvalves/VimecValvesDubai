---
import main_padding from "@/styles/padding";
import { Image } from "astro:assets";
import type { Entry, EntrySkeletonType } from "contentful";

import { documentToHtmlString } from "@contentful/rich-text-html-renderer";

type Props = {
  data: Entry<EntrySkeletonType, undefined, string>;
};

const { data } = Astro.props;
---

<section
  class={`wrapper text-black h-min grid md:grid-cols-2 gap-10 md:mt-32 mt-28 ${main_padding.y}`}
>
  <div class="flex flex-col">
    <h1 class="lg:text-5xl text-4xl mb-2 font-medium capitalize leading-[120%]">
      {data.fields.title}
    </h1>
    <span
      set:html={documentToHtmlString(data.fields.content)}
      class="[&_h3]:text-3xl flex flex-col gap-6 [&_li]:list-disc [&_ul]:ml-4"
    />
  </div>
  <div class="flex size-full items-start justify-center">
    <Image
      src={data.fields.image.fields.file.url}
      alt={data.fields.image.fields.file.fileName}
      width={500}
      height={600}
      class="rounded-xl overflow-hidden object-center object-cover max-md:w-full max-md:max-h-[400px]"
    />
  </div>
</section>
