---
import { Icon } from "astro-icon/components";
import LanguageSwitcher from "./LanguageSwitcher.astro";
import logo from "@/assets/image/Logo-changing.gif";
import { Image } from "astro:assets";

interface Props {
  alternateUrls?: Record<string, string>;
}
const { alternateUrls } = Astro.props;

const locale = Astro.currentLocale as "en" | "it";

import MobileMenu from "./MobileMenu.astro";
import Link from "@/libs/helpers/Link.astro";
import { ui, links } from "@/i18n/ui";

import { getRelativeLocaleUrl } from "astro:i18n";
import CustomBtn from "@/ui/CustomBtn.astro";
import SearchComponent from "./SearchComponent";
import { socialMedia } from "@/libs/content/mics";
import { contentfulClient } from "@/libs/content/contentful/data";
import {
  type TypeApprovals,
  type TypeDepartmentAboutUs,
  type TypeDownloads,
  type TypeGallery,
  type TypeNewsNEvents,
  type TypeProduct,
} from "@/libs/content/contentful/entriesType";
import Logo from "./Logo.astro";
import { slugify } from "@/libs/utils/slugify";
import { getLocalizedPath } from "@/i18n/routes";

// @ts-ignore
const link = (l: string) => {
  const parts = l.split('/');
  const translatedBase = getLocalizedPath(parts[0], locale!).replace(/^\//, '');
  const finalPath = [translatedBase, ...parts.slice(1)].filter(Boolean).join('/');
  return getRelativeLocaleUrl(locale!, finalPath);
};

const [product, downloads, newsEvents, gallery, departmentAboutUs] =
  await Promise.all([
    contentfulClient.getEntries<TypeProduct>({
      content_type: "product",
      locale: locale,
      limit: 6,
    }),

    contentfulClient.getEntries<TypeDownloads>({
      content_type: "downloads",
      locale: locale,
    }),

    contentfulClient.getEntries<TypeNewsNEvents>({
      content_type: "newsEvents",
      locale: locale,
    }),
    contentfulClient.getEntries<TypeGallery>({
      content_type: "gallery",
      locale: locale,
    }),

    contentfulClient.getEntries<TypeDepartmentAboutUs>({
      content_type: "departmentAboutUs",
      locale: locale,
      order: ["sys.createdAt"],
    }),
  ]);

const localSearchData = [
  {
    title: "Contact Md",

    content: "",
    link: link("/contact_us#contact-md"),
  },
  {
    title: "Our Products",

    content:
      "Discover our precision-engineered valves, crafted to meet the demanding standards of the oil and gas industry with unmatched quality and reliability",
    link: link("/products"),
  },
  {
    title: "About us",

    content: `Vimec Group Italia Srl., formerly known as Vimec Srl. (Since 1967), operates from a state-of-the-art manufacturing facility in Cividate Al Piano, Bergamo, Italy.

    Established in 1967 in Opera Milan, Italy, Vimec Srl. built a legacy of excellence in valve manufacturing. In 2018, the company transitioned to Vimec Group Italia Srl., securing exclusive global manufacturing rights for its trademark Vimec Valves.

    We ensure that no other company in Italy is authorized to manufacture or supply valves under the Vimec Valves trademark, which is legally registered to safeguard its integrity and reputation.

    Our new facility is equipped with cutting-edge resources, advanced machinery, ERP software, and enhanced designs to provide efficient, high-quality products and services. With over 50 years of expertise, Vimec Valves continues to lead in reliability and performance.

    Vimec Valves are trusted globally across industries such as Oil & Gas, Chemical, Petrochemical, and Power Plants, delivering exceptional solutions for critical engineering applications.

    At Vimec Group Italia, our commitment is to deliver unmatched quality and expertise. With a forward-thinking approach, we are confident in exceeding our clients' expectations and driving future growth.`,
    link: link("/about-us"),
  },
  {
    title: "Our History",

    content: `1967
    Vimec, was established in 1967 in Opera, Milan, Italy by Ernesto Pighetti as an individual craft company to produce different mechanical components (machining on behalf of third-party companies).

    1985
    In 1985, with its ideology of continuous improvement, Vimec upgraded the technological content of its products and commenced the manufacturing of Industrial Valves, Instrumentation & Accessories such as Manifolds, Double Block and Bleed Valves, Monoflanges, Ball Valves, Needle Valves, Multiport, Check Valves, Globe Valves, Condensing Pots, Distribution Manifolds, Air Headers Distributors, Sampling Cylinders and accessories.

    1994
    In 1994, the company Vimec Srl was established and took over the individual craft company. Since the inception of the company Vimec Srl, it offers a wide variety of valves to meet different kinds of applications with a heritage that exceeds 50 years and a pioneer of Double Block and Bleed and Instrumentation Valves.

    2013
    In 2013, Vimec Srl, had diversified its range into other valve packages to include Gate, Globe, Check and Butterfly Valves in a variety of alloys, trims, configurations, sizes and pressure classes, from general to severe applications for the (Oil & Gas, Chemical, Petrochemical and Power Plants).

    2018
    In 2018, the company Vimec Group Italia Srl has been established and acquired the trademark Vimec Valves and all its manufacturing rights globally.`,
    link: link("/about-us#our-history"),
  },
  {
    title: "Get in touch",

    content: `Looking for Reliable Valve Solutions? Contact Us!
              As a trusted valve manufacturer, we're ready to support your needs. Reach out today to discuss how we can deliver high-quality solutions for your project`,
    link: link("/contact_us"),
  },
  {
    title: "News & Events",

    content: `Stay updated with the latest news, industry insights, and events from Vimec Valves as we continue to innovate and lead in the oil and gas sector.`,
    link: link("/news-events"),
  },
  {
    title: "Downloads",

    content: `Access our latest catalogs, technical specifications, and product manuals to learn more about our high-quality valves for the oil and gas industry.`,
    link: link("/downloads"),
  },
  {
    title: "Gallery",

    content: `Explore our journey through image showcasing our advanced manufacturing, precision engineered valves, and commitment to excellence in the oil and gas industry.`,
    link: link("/gallery"),
  },
];

const processItems = (
  items: any[],
  mapFunction: {
    (item: any): { title: any; content: any; link: string };
    (item: any): { title: any; content: any; link: any };
    (item: any): { title: any; content: any; link: string };
    (item: any): { title: any; content: null; link: string };
  },
) => {
  if (!items) {
    return [];
  }
  return items.map(mapFunction);
};

const dataForSearch = () => {
  const results = [
    ...processItems(
      product?.items,
      (item: {
        fields: { name: any; description: any };
        sys: { id: string };
      }) => ({
        title: item.fields.name,
        content: item.fields.description,
        link: link("products/" + item.sys.id),
      }),
    ),
    ...processItems(
      downloads?.items,
      (item: {
        fields: {
          title: any;
          file: { fields: { file: { fileName: any; url: any } } };
        };
      }) => ({
        title: item.fields.title,
        content: item.fields.file?.fields.file.fileName,
        link: link("downloads/#" + item.fields.title),
      }),
    ),
    ...processItems(
      newsEvents?.items,
      (item: {
        fields: { title: any; description: any; slug?: string };
        sys: { id: string };
      }) => ({
        title: item.fields.title,
        content: item.fields.description,
        link: link("news-events/" + (item.fields.slug ?? slugify(item.fields.title))),
      }),
    ),
    ...processItems(
      gallery?.items,
      (item: { fields: { title: any; slug?: string }; sys: { id: string } }) => ({
        title: item.fields.title,
        content: null,
        link: link("gallery/" + (item.fields.slug ?? slugify(item.fields.title))),
      }),
    ),
    ...localSearchData,
  ];

  return results;
};

const navLinks = links.map((item) => {
  switch (item.key) {
    case "about":
      return {
        ...item,
        list: departmentAboutUs.items.map((item: any) => {
          return {
            title: item.fields.title.replace(/\s*\(.*?\)\s*/g, ""),
            link: "about-us/" + (item.fields.slug ?? slugify(item.fields.title)),
          };
        }),
      };
    default:
      return item;
  }
});
---

<nav
  transition:name="header"
  class="absolute top-0 z-50 flex w-full flex-col"
>
  <div class="bg-vim-blue w-full py-4 relative z-[2000]">
    <div class="wrapper flex items-center justify-between gap-10 sm:gap-20">
      <div class="flex items-center justify-start gap-10">
        <a
          href="tel:+441902953025"
          aria-label="Call +44 1902 953025"
          class="flex items-center justify-start gap-1 text-white"
        >
          <Icon name="ic:round-phone" /> +44 1902 953025
        </a>
        <a
          href="mailto:sales@vimecvalves.co.uk"
          aria-label="Email sales@vimecvalves.co.uk"
          class="flex items-center justify-start gap-1 text-white max-md:hidden"
        >
          <Icon name="material-symbols-light:mail" /> sales@vimecvalves.co.uk
        </a>
      </div>
      <div class="flex items-center justify-end gap-10">
        <div
          class="flex items-center justify-start gap-4 text-base text-white max-lg:hidden"
        >
          {
            socialMedia.map((item) => (
              <a href={item.link} target="_blank" aria-label={`Visit our ${item.icon.split(':')[1] || 'Social'} page`} class="p-2">
                <Icon name={item.icon} class="hover:text-white/50" />
              </a>
            ))
          }
        </div>
        <LanguageSwitcher locale={locale!} alternateUrls={alternateUrls} />
      </div>
    </div>
  </div>
  <div id="main-nav-header" class="wrapper flex items-center justify-between gap-10 py-4 w-full">
    <Link href="/">
      <!-- <Image
        src={logo}
        alt=""
        class="h-16 scale-[130%] object-contain w-auto"
        fetchpriority="high"
      /> -->
      <Logo />
    </Link>
    <menu
      class="flex items-center justify-center gap-6 text-center font-medium uppercase max-xl:text-sm max-lg:hidden"
    >
      {
        navLinks.map((item, idx) => (
          <li
            class="desktop-nav-item relative z-0 flex items-center justify-center"
            data-index={idx}
            data-has-list={item.list ? "true" : "false"}
          >
            <a
              href={getRelativeLocaleUrl(locale!, getLocalizedPath(item.link, locale!).replace(/^\//, ''))}
              class="desktop-nav-link flex items-center justify-center gap-2 whitespace-nowrap"
              data-index={idx}
            >
              {ui[locale].sections.nav[item.key]}{" "}
              {item.list && (
                <Icon
                  name="weui:arrow-outlined"
                  class="desktop-nav-arrow rotate-90 text-2xl transition-transform duration-500 ease-in-out max-xl:text-xl"
                />
              )}
            </a>
            {item.list && (
              <ul
                class="desktop-nav-dropdown absolute top-full left-1/2 hidden w-max max-w-[240px] -translate-x-1/2 flex-col gap-2 rounded-[3px] border border-[#C1C1C1] bg-white p-4 text-start uppercase shadow-lg duration-300"
              >
                {item.list.map((subItem) => (
                  <li>
                    <Link href={subItem.link} class="hover:text-black/80 block py-1">
                      {subItem.title}
                    </Link>
                  </li>
                ))}
              </ul>
            )}
          </li>
        ))
      }
    </menu>

    <div class="flex items-center gap-5 max-lg:hidden">
      <SearchComponent data={dataForSearch()} client:idle />

      <CustomBtn
        href="contact_us"
        className="uppercase max-xl:text-xs lg:px-3 2xl:px-6"
      >
        {ui[locale].buttons.contact}
      </CustomBtn>
    </div>

    <div class="lg:hidden z-0 mobile-menu-container">
      <button
        id="mobile-menu-open-btn"
        aria-label="Open mobile menu"
        class="relative z-0 flex flex-col items-center justify-evenly p-2 w-10 h-10 border-2 border-vim-blue rounded-lg gap-1"
      >
        <span class="w-full h-0.5 bg-vim-blue rounded-full duration-300 transform line-1"></span>
        <span class="w-full h-0.5 bg-vim-blue rounded-full duration-300 line-2"></span>
        <span class="w-full h-0.5 bg-vim-blue rounded-full duration-300 transform line-3"></span>
      </button>
    </div>
  </div>
</nav>

<MobileMenu
  links={navLinks!}
  locale={locale!}
  searchData={dataForSearch()}
/>

<script>
  function setupDesktopNav() {
    const navItems = document.querySelectorAll<HTMLLIElement>('.desktop-nav-item[data-has-list="true"]');
    const supportsHover = window.matchMedia('(hover: hover)').matches;
    let openIndex: string | null = null;

    function openDropdown(li: HTMLLIElement, idx: string | null) {
      const dropdown = li.querySelector<HTMLElement>('.desktop-nav-dropdown');
      const arrow = li.querySelector<HTMLElement>('.desktop-nav-arrow');
      dropdown?.classList.remove('hidden');
      dropdown?.classList.add('flex');
      arrow?.classList.remove('rotate-90');
      arrow?.classList.add('-rotate-90');
      openIndex = idx;
    }

    function closeDropdown(li: HTMLLIElement) {
      const dropdown = li.querySelector<HTMLElement>('.desktop-nav-dropdown');
      const arrow = li.querySelector<HTMLElement>('.desktop-nav-arrow');
      dropdown?.classList.remove('flex');
      dropdown?.classList.add('hidden');
      arrow?.classList.remove('-rotate-90');
      arrow?.classList.add('rotate-90');
    }

    function closeAll() {
      navItems.forEach((li) => closeDropdown(li));
      openIndex = null;
    }

    navItems.forEach((li) => {
      const link = li.querySelector<HTMLAnchorElement>('.desktop-nav-link');
      const idx = li.getAttribute('data-index');

      if (supportsHover) {
        // ── Hover-capable devices (desktop mouse) ──────────────────────────
        li.addEventListener('mouseenter', () => openDropdown(li, idx));
        li.addEventListener('mouseleave', () => closeDropdown(li));

        // On hover devices, clicking the parent link always navigates
        // (dropdown is already visible on hover, no need to intercept)
        link?.addEventListener('click', () => closeAll());

      } else {
        // ── Touch / no-hover devices (tablets, phones) ─────────────────────
        link?.addEventListener('click', (e) => {
          if (openIndex === idx) {
            // Second click → navigate normally
            closeAll();
            return;
          }
          // First click → open dropdown, block navigation
          e.preventDefault();
          closeAll();
          openDropdown(li, idx);
        });
      }
    });

    // Close on outside click (both modes)
    document.addEventListener('click', (e) => {
      const target = e.target as Node;
      const inside = Array.from(navItems).some((li) => li.contains(target));
      if (!inside) closeAll();
    });

    // Close on Escape (both modes)
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeAll();
    });
  }

  function setupStickyNav() {
    const header = document.querySelector("#main-nav-header");
    if (!header) return;

    let ticking = false;
    window.addEventListener("scroll", () => {
      if (!ticking) {
        window.requestAnimationFrame(() => {
          if (window.scrollY > 40) {
            header.classList.add("scrolled");
          } else {
            header.classList.remove("scrolled");
          }
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });
  }

  document.addEventListener('astro:page-load', () => {
    setupDesktopNav();
    setupStickyNav();
  });
</script>

<style>
  #main-nav-header {
    position: sticky;
    top: 0;
    z-index: 1000;
    transform: translateY(0);
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1), background 0.25s ease, box-shadow 0.25s ease, backdrop-filter 0.25s ease;
  }

  #main-nav-header::before {
    content: "";
    position: absolute;
    inset: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 100vw;
    height: 100%;
    background: white;
    z-index: -1;
    transition: background 0.25s ease, box-shadow 0.25s ease, backdrop-filter 0.25s ease;
  }

  /* To make sticky work correctly inside an absolute container layout or when fixed */
  #main-nav-header.scrolled {
    position: fixed;
    top: 0;
    transform: translateY(0);
    left: 0;
    right: 0;
    margin: 0 auto;
  }

  #main-nav-header.scrolled::before {
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.08);
  }
</style>
