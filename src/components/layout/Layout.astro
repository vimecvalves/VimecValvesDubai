---
import { ClientRouter } from "astro:transitions";
import Header from "./Header/index.astro";
import Footer from "./Footer.astro";

import "@/styles/global.css";
import "@/assets/font/sf-pro-display/stylesheet.css";
import sfProBold from "@/assets/font/sf-pro-display/SFProDisplay-Bold.woff2";
import sfProMedium from "@/assets/font/sf-pro-display/SFProDisplay-Medium.woff2";
import sfProRegular from "@/assets/font/sf-pro-display/SFProDisplay-Regular.woff2";

interface Props {
  hideTopFooter?: boolean;
  title?: string;
  description?: string;
}

const { 
  hideTopFooter = false, 
  title = "Best Quality Sampling Valve Manufacturers in UK | Vimec",
  description = "Vimec Group Italia is one of the best company for quality sampling valve manufacturers in italy for the design, manufacturing and supply of quality industrial valves."
} = Astro.props;
---

<!doctype html>
<html lang="en" class="font-sf-pro overflow-x-hidden scroll-smooth antialiased">
  <head>
    <title>{title}</title>
    <meta
      name="description"
      content={description}
    />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content="index, follow" />
    <ClientRouter />
    <link rel="preload" href={sfProBold} as="font" type="font/woff2" crossorigin="anonymous" />
    <link rel="preload" href={sfProMedium} as="font" type="font/woff2" crossorigin="anonymous" />
    <link rel="preload" href={sfProRegular} as="font" type="font/woff2" crossorigin="anonymous" />
    <!-- Google Tag Manager -->
    <script>
      (function (w, d, s, l, i) {
        w[l] = w[l] || [];
        w[l].push({ "gtm.start": new Date().getTime(), event: "gtm.js" });
        var f = d.getElementsByTagName(s)[0],
          j = d.createElement(s),
          dl = l != "dataLayer" ? "&l=" + l : "";
        j.async = true;
        j.src = "https://www.googletagmanager.com/gtm.js?id=" + i + dl;
        f.parentNode.insertBefore(j, f);
      })(window, document, "script", "dataLayer", "GTM-MPQZFGXD");
    </script>
    <!-- End Google Tag Manager -->
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />
    <script type="application/ld+json" is:inline>
      [
        {
          "@context": "https://schema.org",
          "@type": "Organization",
          "name": "Vimec Valves",
          "url": "https://www.vimecvalves.co.uk",
          "logo": "https://www.vimecvalves.co.uk/favicon.ico",
          "contactPoint": {
            "@type": "ContactPoint",
            "telephone": "+44 1902 953025",
            "email": "sales@vimecvalves.co.uk",
            "contactType": "customer service"
          },
          "address": {
            "@type": "PostalAddress",
            "streetAddress": "Via Lago d'Iseo, 5",
            "addressLocality": "Bolgare",
            "addressRegion": "BG",
            "postalCode": "24060",
            "addressCountry": "IT"
          },
          "sameAs": [
            "https://www.linkedin.com/company/vimecvalves/",
            "https://www.instagram.com/vimecvalves/",
            "https://www.facebook.com/vimecvalves",
            "https://youtube.com/@vimecvalves?si=qitjEZGxWVgIxxOA"
          ]
        },
        {
          "@context": "https://schema.org",
          "@type": "Manufacturer",
          "name": "Vimec Valves",
          "description": "Industrial valves manufacturer for oil & gas sector.",
          "url": "https://www.vimecvalves.co.uk"
        }
      ]
    </script>
    <script is:inline>document.documentElement.classList.add('js');</script>
    <slot name="head" />
  </head>
  <body>
    <Header />
    <main role="main">
      <slot />
    </main>
    <Footer hideTop={hideTopFooter} />
    <!-- Google Tag Manager (noscript) -->
    <noscript
      ><iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-MPQZFGXD"
        height="0"
        width="0"
        style="display:none;visibility:hidden"></iframe></noscript
    >
    <!-- End Google Tag Manager (noscript) -->
    <script>
      function initRevealAnimations() {
        const observerOptions = {
          threshold: 0.05,
          rootMargin: "0px 0px 0px 0px",
        };

        const observer = new IntersectionObserver((entries) => {
          let staggerIndex = 0;
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const delay = Math.min(staggerIndex * 0.1, 0.5);
              entry.target.style.transitionDelay = `${delay}s`;
              entry.target.classList.add("reveal-visible");
              observer.unobserve(entry.target);
              staggerIndex++;
            }
          });
          
          setTimeout(() => {
            staggerIndex = 0;
          }, 100);
        }, observerOptions);

        const revealElements = document.querySelectorAll(
          ".reveal-up, .reveal-down"
        );
        revealElements.forEach((el) => observer.observe(el));
      }

      document.addEventListener("DOMContentLoaded", initRevealAnimations);
      document.addEventListener("astro:page-load", initRevealAnimations);
    </script>
  </body>
</html>

<style>
  html,
  body {
    background: white;
  }
  @view-transition {
    navigation: auto;
  }
</style>
