---
import Link from "@/libs/helpers/Link.astro";
import { Icon } from "astro-icon/components";

interface Props {
  data: {
    link: string;
    title?: string;
  }[];
}

const { data } = Astro.props;

const siteUrl = Astro.site ? Astro.site.toString().replace(/\/$/, "") : "https://www.vimec-valves.ae";
const locale = Astro.currentLocale || "en";

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": data.map((item, index) => {
    let finalLink = item.link;
    if (!finalLink || finalLink === "") {
        finalLink = Astro.url.pathname;
    } else if (finalLink === "/") {
        finalLink = `/${locale}`;
    } else {
        finalLink = `/${locale}${finalLink.startsWith('/') ? '' : '/'}${finalLink}`;
    }
    return {
      "@type": "ListItem",
      "position": index + 1,
      "name": item.title,
      "item": `${siteUrl}${finalLink.replace(/\/$/, '')}`
    };
  })
};
---

<menu class:list={["flex items-center gap-1 font-medium flex-wrap"]}>
  {
    data.map((item, idx) => (
      <Link href={item.link} class="flex items-center gap-1">
        {item.title}
        {idx < data.length - 1 && (
          <Icon name="weui:arrow-outlined" class="text-xl" />
        )}
      </Link>
    ))
  }
</menu>
<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
