---
// @ts-nocheck
import { Image } from "astro:assets";
import { twMerge } from "tailwind-merge";
import Link from "@/libs/helpers/Link.astro";
import type { TypeProduct } from "@/libs/content/contentful/entriesType";
import type { Entry } from "contentful";

interface Props extends Entry<TypeProduct, undefined, string> {
  className?: string;
}

const { fields, sys, className } = Astro.props;

const { name, images, category } = fields;

---

<Link
  href={`/products/${encodeURIComponent(sys.id)}`}
  class={twMerge(
    `bg-gradient-to-br from-[#f8fbff] via-[#ffffff] to-[#f6faff] border border-blue-50 rounded-2xl shadow-[0_1px_2px_rgba(0,0,0,0.04)] hover:-translate-y-[3px] backdrop-blur-[2px] transition-transform duration-200 w-full px-6 py-6 flex items-start justify-start flex-col `,
    className,
  )}
>
  <div class="mb-6 flex aspect-square h-auto items-center justify-center">
    <Image
      src={images[0].fields.file.url}
      alt={images[0].fields.file.fileName}
      width={250}
      height={250}
      class="h-full w-full object-cover"
    />
  </div>
  <span class="text-vim-blue text-lg font-medium uppercase">
    {category.fields?.title}
  </span>
  <h3 class="text-2xl font-medium">{name}</h3>
</Link>
