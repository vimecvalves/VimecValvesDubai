---
// @ts-nocheck
import { Image } from "astro:assets";
import { twMerge } from "tailwind-merge";
import Link from "@/libs/helpers/Link.astro";
import type { TypeProduct } from "@/libs/content/contentful/entriesType";
import type { Entry } from "contentful";

interface Props extends Entry<TypeProduct, undefined, string> {
  className?: string;
  eagerLoading?: boolean;
}

const { fields, sys, className, eagerLoading = false } = Astro.props;

const { name, images, category } = fields;

---

<Link
  href={`/products/${encodeURIComponent(sys.id)}`}
  class={twMerge(
    `reveal-up bg-gradient-to-br from-[#f8fbff] via-[#ffffff] to-[#f6faff] border border-blue-50 rounded-2xl shadow-sm hover:shadow-[0_20px_40px_-15px_rgba(0,0,0,0.1)] hover:-translate-y-[8px] backdrop-blur-[2px] transition-all duration-300 w-full h-full px-8 py-8 flex flex-col items-start justify-start group`,
    className,
  )}
>
  <div class="mb-4 flex h-56 w-full flex-shrink-0 items-center justify-center overflow-hidden bg-white/50 rounded-lg">
    <Image
      src={`${images[0].fields.file.url}?fm=webp&q=80&w=640`}
      alt={name || "Product preview"}
      width={320}
      height={320}
      loading={eagerLoading ? "eager" : "lazy"}
      fetchpriority={eagerLoading ? "high" : "auto"}
      class="h-full w-full object-contain group-hover:scale-110 transition-transform duration-500"
    />
  </div>
  <div class="flex flex-col flex-grow items-start justify-start w-full">
    <span class="text-vim-blue text-sm sm:text-base md:text-lg font-medium uppercase mb-2">
      {category.fields?.title}
    </span>
    <h3 class="text-xl sm:text-2xl font-medium line-clamp-2 w-full leading-tight text-left">
      {name}
    </h3>
  </div>
</Link>
