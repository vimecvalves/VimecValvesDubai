---
type Props = astroHTML.JSX.AnchorHTMLAttributes & {
  invert?: boolean;
  className?: string;
  herf: string;
};

const { invert = false, href = "/", className = "", ...props } = Astro.props;
const classes = [
  "px-6 py-2.5 border rounded-md font-medium text-center duration-300 cursor-pointer",
  invert
    ? "text-white bg-vim-blue hover:bg-white hover:text-vim-blue border-2 border-vim-blue"
    : "hover:text-white text-vim-blue hover:bg-vim-blue border-vim-blue",
  className,
].join(" ");

const locale = Astro.currentLocale as "en" | "it";

import { getRelativeLocaleUrl } from "astro:i18n";

const link = href
  ? getRelativeLocaleUrl(locale, href as string)
  : "javascript:void(0)";
---

<a class={classes} href={link} {...props} >
  <slot />
</a>
