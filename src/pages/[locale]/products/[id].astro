---
import GetInTouch from "@/components/home/GetInTouch.astro";
import Layout from "@/components/layout/Layout.astro";
import HeroSection from "@/components/products/[id]/HeroSection.astro";
export const prerender = false;

import RelatedProducts from "@/components/products/[id]/RelatedProducts.astro";
import { contentfulClient } from "@/libs/content/contentful/data";
import type { TypeProduct } from "@/libs/content/contentful/entriesType";

const { id, local } = Astro.params;

const data = await contentfulClient.getEntry<TypeProduct>(id!, {
  locale: local,
});

const productSchema = {
  "@context": "https://schema.org/",
  "@type": "Product",
  "name": data.fields.name,
  "description": data.fields.cardDescription || `Learn more about ${data.fields.name} designed by Vimec Valves for industrial sampling and process applications.`,
  "image": data.fields.images && data.fields.images.length > 0 && data.fields.images[0]?.fields?.file?.url 
    ? `https:${data.fields.images[0].fields.file.url}` 
    : undefined,
  "brand": {
    "@type": "Brand",
    "name": "Vimec Valves"
  },
  "url": new URL(Astro.url.pathname, Astro.site).toString()
};
---

<Layout
  title={data.fields.name ? `${data.fields.name} | Vimec Valves` : "Product | Vimec Valves"}
  description={`Learn more about ${data.fields.name} designed by Vimec Valves for industrial sampling and process applications.`}
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(productSchema)} />
  <HeroSection {...data} />

  {(data.fields.material || data.fields.pressureRating || data.fields.temperatureRange || data.fields.connectionType || data.fields.certifications) && (
    <section class="wrapper sm:my-10 my-6">
      <h2 class="lg:text-5xl text-4xl font-medium mb-8">Technical Specifications</h2>
      <div class="overflow-x-auto w-full">
        <table class="w-full text-left border-collapse border border-gray-300 text-lg">
          <tbody>
            {data.fields.material && (
              <tr class="border-b border-gray-300">
                <th class="p-4 bg-[#F4F4F4] font-medium w-1/3 border-r border-gray-300">Material</th>
                <td class="p-4">{data.fields.material}</td>
              </tr>
            )}
            {data.fields.pressureRating && (
              <tr class="border-b border-gray-300">
                <th class="p-4 bg-[#F4F4F4] font-medium w-1/3 border-r border-gray-300">Pressure Rating</th>
                <td class="p-4">{data.fields.pressureRating}</td>
              </tr>
            )}
            {data.fields.temperatureRange && (
              <tr class="border-b border-gray-300">
                <th class="p-4 bg-[#F4F4F4] font-medium w-1/3 border-r border-gray-300">Temperature Range</th>
                <td class="p-4">{data.fields.temperatureRange}</td>
              </tr>
            )}
            {data.fields.connectionType && (
              <tr class="border-b border-gray-300">
                <th class="p-4 bg-[#F4F4F4] font-medium w-1/3 border-r border-gray-300">Connection Type</th>
                <td class="p-4">{data.fields.connectionType}</td>
              </tr>
            )}
            {data.fields.certifications && (
              <tr class="border-b border-gray-300">
                <th class="p-4 bg-[#F4F4F4] font-medium w-1/3 border-r border-gray-300">Certifications</th>
                <td class="p-4">{data.fields.certifications}</td>
              </tr>
            )}
          </tbody>
        </table>
      </div>
    </section>
  )}

  {data.fields.relatedProducts && <RelatedProducts {...data} />}
  <GetInTouch />
</Layout>
