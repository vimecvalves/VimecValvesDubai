---
import GetInTouch from "@/components/home/GetInTouch.astro";
import Layout from "@/components/layout/Layout.astro";
import HeroSection from "@/components/products/[id]/HeroSection.astro";
export const prerender = false;

import RelatedProducts from "@/components/products/[id]/RelatedProducts.astro";
import { contentfulClient } from "@/libs/content/contentful/data";
import type { TypeProduct } from "@/libs/content/contentful/entriesType";

const { id, local } = Astro.params;

const data = await contentfulClient.getEntry<TypeProduct>(id!, {
  locale: local,
});
---

<Layout>
  <HeroSection {...data} />
  {data.fields.relatedProducts && <RelatedProducts {...data} />}
  <GetInTouch />
</Layout>
