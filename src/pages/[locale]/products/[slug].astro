---
import GetInTouch from "@/components/home/GetInTouch.astro";
import Layout from "@/components/layout/Layout.astro";
import HeroSection from "@/components/products/[slug]/HeroSection.astro";
export const prerender = false;
import ProductFAQ from "@/components/products/[slug]/ProductFAQ.astro";
import RelatedProducts from "@/components/products/RelatedProducts.astro";
import { contentfulClient } from "@/libs/content/contentful/data";
import type { TypeProduct } from "@/libs/content/contentful/entriesType";
import { slugify } from "@/libs/utils/slugify";

Astro.response.headers.set('Cache-Control', 'public, max-age=0, s-maxage=3600, stale-while-revalidate=86400');

const { slug } = Astro.params;
const local = (Astro.currentLocale || Astro.params.locale) as "en" | "it";
import { routes } from "@/i18n/routes";

const otherLocal = local === "it" ? "en" : "it";

const [allProductsRes, otherProductsRes] = await Promise.all([
  contentfulClient.getEntries<TypeProduct>({
    content_type: 'product',
    locale: local,
  }),
  contentfulClient.getEntries<TypeProduct>({
    content_type: 'product',
    locale: otherLocal,
  })
]);

// Helper to mutate Italian items
const applyItalianTranslations = (items: any[]) => {
  items.forEach(item => {
    const catUpper = item.fields?.category?.fields?.title?.toUpperCase() || '';
    
    // 1. Correct the main product names
    if (['MODULAR', 'COMPACT', 'INTEGRAL'].includes(catUpper)) {
      item.fields.name = 'Valvole Double Block & Bleed';
    } else if (catUpper === 'TRUNNION') {
      item.fields.name = 'Valvole a Sfera Trunnion';
    } else if (['TOP ENTRY', 'FLOATING', 'METAL SEATED'].includes(catUpper)) {
      item.fields.name = 'Valvole a Sfera';
    } else if (['MANIFOLDS', 'MONOFLANGES', 'NEEDLE VALVE'].includes(catUpper)) {
      item.fields.name = 'Strumentazione';
    } else if (['CAST STEEL', 'FORGED STEEL'].includes(catUpper)) {
      item.fields.name = 'Valvole a Saracinesca, Globo e Ritegno';
    } else if (catUpper === 'DUAL PLATE') {
      item.fields.name = 'Valvole di Ritegno';
    } else if (['CONCENTRIC', 'HIGH PERFORMANCE'].includes(catUpper)) {
      item.fields.name = 'Valvole a Farfalla';
    } else {
      let displayName = item.fields.name || '';
      if (displayName.includes('Double Block & Bleed')) item.fields.name = 'Valvole Double Block & Bleed';
      else if (displayName.includes('Ball Valves')) item.fields.name = 'Valvole a Sfera';
      else if (displayName.includes('Instrumentation')) item.fields.name = 'Strumentazione';
      else if (displayName.includes('Gate, Globe, Check')) item.fields.name = 'Valvole a Saracinesca, Globo e Ritegno';
      else if (displayName.includes('Check Valves')) item.fields.name = 'Valvole di Ritegno';
      else if (displayName.includes('Butterfly Valves')) item.fields.name = 'Valvole a Farfalla';
    }

    // 2. Correct Category titles
    if (item.fields.category && item.fields.category.fields) {
      if (catUpper === 'MODULAR') item.fields.category.fields.title = 'Modulare';
      else if (catUpper === 'COMPACT') item.fields.category.fields.title = 'Compatto';
      else if (catUpper === 'INTEGRAL') item.fields.category.fields.title = 'Integrale';
    }
  });
};

if (local === 'it') applyItalianTranslations(allProductsRes.items);
if (otherLocal === 'it') applyItalianTranslations(otherProductsRes.items);

const getSlug = (item: any) => {
  const catTitle = item.fields.category?.fields?.title || '';
  return item.fields.slug ?? slugify(`${catTitle ? catTitle + '-' : ''}${item.fields.name}`);
};

const allProducts = allProductsRes;
let data = allProducts.items.find(item => getSlug(item) === slug);
let alternateUrls: Record<string, string> = {};

if (!data) {
  // If not found in current locale, check other locale
  const otherDataMatch = otherProductsRes.items.find(item => getSlug(item) === slug);
  if (otherDataMatch) {
    const currentLocData = allProducts.items.find(i => i.sys.id === otherDataMatch.sys.id);
    if (currentLocData) {
       return Astro.redirect(`/${local}/${routes.products[local]}/${getSlug(currentLocData)}`, 301);
    }
  }
  return new Response(null, { status: 404, statusText: 'Not found' });
} else {
  // Data is found, compute alternate URLs
  const otherLocData = otherProductsRes.items.find(i => i.sys.id === data.sys.id);
  
  alternateUrls = {
    [local]: `/${local}/${routes.products[local]}/${getSlug(data)}`,
    [otherLocal]: `/${otherLocal}/${routes.products[otherLocal]}/${otherLocData ? getSlug(otherLocData) : getSlug(data)}`
  };
}


const additionalProperty = [];

if (data.fields.category?.fields?.title) {
  additionalProperty.push({ "@type": "PropertyValue", "name": "Valve Type", "value": data.fields.category.fields.title });
}
if (data.fields.material) {
  additionalProperty.push({ "@type": "PropertyValue", "name": "Body Material", "value": data.fields.material });
}
if (data.fields.pressureRating) {
  additionalProperty.push({ "@type": "PropertyValue", "name": "Pressure Rating", "value": data.fields.pressureRating });
}
if (data.fields.temperatureRange) {
  additionalProperty.push({ "@type": "PropertyValue", "name": "Temperature Range", "value": data.fields.temperatureRange });
}
if (data.fields.connectionType) {
  additionalProperty.push({ "@type": "PropertyValue", "name": "Connection Type", "value": data.fields.connectionType });
}
if (data.fields.certifications) {
  additionalProperty.push({ "@type": "PropertyValue", "name": "Industry Standards", "value": data.fields.certifications });
}

const productSchema = {
  "@context": "https://schema.org/",
  "@type": "Product",
  "name": data.fields.name,
  "description": data.fields.cardDescription || `Learn more about ${data.fields.name} designed by Vimec Valves for industrial sampling and process applications.`,
  "image": data.fields.images && data.fields.images.length > 0 && data.fields.images[0]?.fields?.file?.url 
    ? `https:${data.fields.images[0].fields.file.url}` 
    : undefined,
  "brand": {
    "@type": "Brand",
    "name": "Vimec Valves"
  },
  "url": new URL(Astro.url.pathname, Astro.site).toString(),
  "offers": {
    "@type": "Offer",
    "url": new URL(Astro.url.pathname, Astro.site).toString(),
    "priceCurrency": "GBP",
    "priceSpecification": {
      "@type": "PriceSpecification",
      "price": "0"
    },
    "availability": "https://schema.org/InStock"
  },
  "additionalProperty": additionalProperty.length > 0 ? additionalProperty : undefined
};

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Industrial Valves",
  "itemListElement": allProducts.items.map((item, index) => {
    const catTitle = item.fields.category?.fields?.title || '';
    const fallbackSlug = slugify(`${catTitle ? catTitle + '-' : ''}${item.fields.name}`);
    const slugItem = item.fields.slug ?? fallbackSlug;
    return {
      "@type": "ListItem",
      "position": index + 1,
      "url": new URL(`/${local}/${routes.products[local]}/${slugItem}`, Astro.site).toString(),
      "name": item.fields.name
    };
  })
};
---

<Layout
  title={data.fields.name ? `${data.fields.name} Manufacturer | Industrial Valves | Vimec` : "Industrial Valve Manufacturer | Vimec"}
  description={`Explore our range of industrial sampling valves and process valves designed for oil, gas and process industries. Learn details about ${data.fields.name}.`}
  alternateUrls={alternateUrls}
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(productSchema)} />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />
  <HeroSection {...data} />

  {(data.fields.material || data.fields.pressureRating || data.fields.temperatureRange || data.fields.connectionType || data.fields.certifications) && (
    <section class="wrapper sm:my-10 my-6">
      <h2 class="lg:text-5xl text-4xl font-medium mb-8">Technical Specifications</h2>
      <div class="overflow-x-auto w-full">
        <table class="w-full text-left border-collapse border border-gray-300 text-lg">
          <tbody>
            {data.fields.material && (
              <tr class="border-b border-gray-300">
                <th class="p-4 bg-[#F4F4F4] font-medium w-1/3 border-r border-gray-300">Material</th>
                <td class="p-4">{data.fields.material}</td>
              </tr>
            )}
            {data.fields.pressureRating && (
              <tr class="border-b border-gray-300">
                <th class="p-4 bg-[#F4F4F4] font-medium w-1/3 border-r border-gray-300">Pressure Rating</th>
                <td class="p-4">{data.fields.pressureRating}</td>
              </tr>
            )}
            {data.fields.temperatureRange && (
              <tr class="border-b border-gray-300">
                <th class="p-4 bg-[#F4F4F4] font-medium w-1/3 border-r border-gray-300">Temperature Range</th>
                <td class="p-4">{data.fields.temperatureRange}</td>
              </tr>
            )}
            {data.fields.connectionType && (
              <tr class="border-b border-gray-300">
                <th class="p-4 bg-[#F4F4F4] font-medium w-1/3 border-r border-gray-300">Connection Type</th>
                <td class="p-4">{data.fields.connectionType}</td>
              </tr>
            )}
            {data.fields.certifications && (
              <tr class="border-b border-gray-300">
                <th class="p-4 bg-[#F4F4F4] font-medium w-1/3 border-r border-gray-300">Certifications</th>
                <td class="p-4">{data.fields.certifications}</td>
              </tr>
            )}
          </tbody>
        </table>
      </div>
    </section>
  )}

  <RelatedProducts 
    currentProductId={data.sys.id} 
    categoryTitle={data.fields.category?.fields?.title || ''} 
    allProducts={allProducts.items} 
  />
  <ProductFAQ />

  <GetInTouch />
</Layout>
