---
import GetInTouch from "@/components/home/GetInTouch.astro";
import Layout from "@/components/layout/Layout.astro";
import { ui } from "@/i18n/ui";
import { contentfulClient } from "@/libs/content/contentful/data";
import type { TypeProduct } from "@/libs/content/contentful/entriesType";
import main_padding from "@/styles/padding";
import HeroSectionHeader from "@/ui/HeroSectionHeader.astro";
import ProductCard from "@/ui/ProductCard.astro";

import { getRelativeLocaleUrlList } from "astro:i18n";

export const prerender = false;
Astro.response.headers.set('Cache-Control', 'public, max-age=0, s-maxage=3600, stale-while-revalidate=86400');

const local = Astro.currentLocale as "en" | "it";

const data = await contentfulClient.getEntries<TypeProduct>({
  content_type: "product",
  locale: local,
});

if (local === 'it') {
  data.items.forEach(item => {
    const catUpper = item.fields?.category?.fields?.title?.toUpperCase() || '';
    
    // 1. Correct the main product names based on their category mappings (since Italian names are wiped or broken as 'INTÉGRALE')
    if (['MODULAR', 'COMPACT', 'INTEGRAL'].includes(catUpper)) {
      item.fields.name = 'Valvole Double Block & Bleed';
    } else if (catUpper === 'TRUNNION') {
      item.fields.name = 'Valvole a Sfera Trunnion';
    } else if (['TOP ENTRY', 'FLOATING', 'METAL SEATED'].includes(catUpper)) {
      item.fields.name = 'Valvole a Sfera';
    } else if (['MANIFOLDS', 'MONOFLANGES', 'NEEDLE VALVE'].includes(catUpper)) {
      item.fields.name = 'Strumentazione';
    } else if (['CAST STEEL', 'FORGED STEEL'].includes(catUpper)) {
      item.fields.name = 'Valvole a Saracinesca, Globo e Ritegno';
    } else if (catUpper === 'DUAL PLATE') {
      item.fields.name = 'Valvole di Ritegno';
    } else if (['CONCENTRIC', 'HIGH PERFORMANCE'].includes(catUpper)) {
      item.fields.name = 'Valvole a Farfalla';
    } else {
      // Fallback if there are any others that retain English names
      let displayName = item.fields.name || '';
      if (displayName.includes('Double Block & Bleed')) item.fields.name = 'Valvole Double Block & Bleed';
      else if (displayName.includes('Ball Valves')) item.fields.name = 'Valvole a Sfera';
      else if (displayName.includes('Instrumentation')) item.fields.name = 'Strumentazione';
      else if (displayName.includes('Gate, Globe, Check')) item.fields.name = 'Valvole a Saracinesca, Globo e Ritegno';
      else if (displayName.includes('Check Valves')) item.fields.name = 'Valvole di Ritegno';
      else if (displayName.includes('Butterfly Valves')) item.fields.name = 'Valvole a Farfalla';
    }

    // 2. Correct specific category subtitle translations requested previously
    if (item.fields.category && item.fields.category.fields) {
      if (catUpper === 'MODULAR') item.fields.category.fields.title = 'Modulare';
      else if (catUpper === 'COMPACT') item.fields.category.fields.title = 'Compatto';
      else if (catUpper === 'INTEGRAL') item.fields.category.fields.title = 'Integrale';
    }
  });
}
---

<Layout
  title="Industrial Sampling Valves & Process Valves | Vimec Valves"
  description="Explore our wide range of high-quality industrial valves, including sampling valves, engineered for optimal performance."
>
  <section
    class:list={[
      "wrapper flex md:mt-32 mt-28 flex-col gap-10 ",
      main_padding.y,
    ]}
  >
    <HeroSectionHeader
      title={ui[local].products["hero-section"].title}
      content={ui[local].products["hero-section"].content}
    />

    <div class="grid lg:grid-cols-4 md:grid-cols-3 sm:grid-cols-2 gap-4">
      {data.items.map((item) => <ProductCard {...item} />)}
    </div>

    <div class="prose max-w-none text-gray-700 mt-8 mb-4">
      <h2 class="text-2xl font-semibold text-[#183a65] mb-4">Leading Manufacturers of Industrial Sampling Valves & Process Valves</h2>
      <p class="mb-4">
        Vimec Valves is globally recognized for the engineering, manufacturing, and distribution of high-quality industrial sampling valves and custom process control solutions. With decades of expertise serving the most demanding sectors—including petrochemical, oil and gas, pharmaceutical, power generation, and chemical processing—we have established ourselves as a consistent benchmark for safety, precision, and reliability.
      </p>
      <p class="mb-4">
        Our industrial valves are meticulously crafted out of premium materials like 316L Stainless Steel, Monel, and Hastelloy to meet rigorous international standards. Designed for zero-emission and dead-space-free operations, our diverse portfolio safely protects personnel and the environment from hazardous exposures.
      </p>
      <p>
        Fully compliant with PED, ATEX, and API norms, every Vimec product undergoes comprehensive quality assurance and non-destructive testing, guaranteeing long-lasting performance even under extreme temperatures and corrosive environments. Explore our comprehensive catalog of bespoke technical solutions above.
      </p>
    </div>
  </section>

  <GetInTouch />
</Layout>
