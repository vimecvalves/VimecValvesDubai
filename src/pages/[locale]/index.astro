---
import HeroSection from "@/components/home/HeroSection.astro";
import SomeCounts from "@/components/home/SomeCounts.astro";
import Layout from "@/components/layout/Layout.astro";
import OurProducts from "@/components/home/OurProducts.astro";
import SupplyReferences from "@/components/home/SupplyReferences.astro";
import OurHistory from "@/components/home/OurHistory.astro";
import NewsEvents from "@/components/home/NewsEvents.astro";
import GetInTouch from "@/components/home/GetInTouch.astro";
import Fallback from "@/components/Fallback.astro";

import { getRelativeLocaleUrlList } from "astro:i18n";
import { contentfulClient } from "@/libs/content/contentful/data";
import type { TypeHomePage } from "@/libs/content/contentful/entriesType";
import { SEO } from "astro-seo";

export const prerender = false;

const data = await contentfulClient.getEntry<TypeHomePage>(
  "1o4D3ppL6nw2flWIQ3L5TD",
);
---

<SEO
  title="Best Quality Sampling Valve Manufacturers in UK | Vimec"
  description="Vimec Group Italia is one of the best company for quality sampling valve manufacturers in italy for the design, manufacturing and supply of quality industrial valves."
/>
<Layout>
  <HeroSection data={data.fields.heroSectionImageSlider!} />
  <SomeCounts />
  <OurProducts server:defer>
    <Fallback slot="fallback" />
  </OurProducts>
  <SupplyReferences server:defer>
    <Fallback slot="fallback" />
  </SupplyReferences>
  <OurHistory />
  <NewsEvents server:defer>
    <Fallback slot="fallback" />
  </NewsEvents>
  <GetInTouch />
</Layout>
