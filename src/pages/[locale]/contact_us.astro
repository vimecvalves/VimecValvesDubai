---
import Layout from "@/components/layout/Layout.astro";

import { getRelativeLocaleUrlList } from "astro:i18n";

import HeroSection from "@/components/contact_us/HeroSection.astro";
import Details from "@/components/contact_us/Details.astro";

export const prerender = true;

export function getStaticPaths() {
  return [
    { params: { locale: 'en' } },
    { params: { locale: 'it' } },
  ];
}
---

<Layout 
  hideTopFooter 
  title="Contact Vimec Valves Middle East | Italian Industrial Valve Supplier"
  description="Contact Vimec Valves Middle East, a trusted Italian industrial valve supplier serving the global oil, gas, and energy industries with high-performance sampling valves."
>
  <HeroSection />
  <Details />
</Layout>

<script is:inline>
  window.addEventListener("load", () => {
    const hash = window.location.hash;

    if (!hash) return;

    const targetId = decodeURIComponent(
      hash.replace("#", "").replace(/\/$/, ""),
    );

    const el = document.getElementById(targetId);

    if (el) {
      el.scrollIntoView({ behavior: "smooth" });
    }
  });
</script>
