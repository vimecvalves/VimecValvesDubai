---
import Layout from "@/components/layout/Layout.astro";
import main_padding from "@/styles/padding";
import Breadcrumbs from "@/ui/Breadcrumbs.astro";
import HeroSectionHeader from "@/ui/HeroSectionHeader.astro";
import { ui } from "@/i18n/ui";
import { contentfulClient } from "@/libs/content/contentful/data";
import ImagesGrid from "@/components/gallery/ImagesGrid";
import Fallback from "@/components/Fallback.astro";

import { slugify } from "@/libs/utils/slugify";
import type { TypeGallery } from "@/libs/content/contentful/entriesType";

const { slug } = Astro.params;
const local = Astro.currentLocale as "en" | "it";

const allGalleries = await contentfulClient.getEntries<TypeGallery>({
  content_type: 'gallery',
  locale: local,
  include: 2,
});

console.log("Gallery URL Slug Param:", slug);
console.log("Gallery Available Slugs:", allGalleries.items.map(e => slugify(e.fields.title)));

const data = allGalleries.items.find((item) => {
  // @ts-ignore
  const itemSlug = item.fields.slug ?? slugify(item.fields.title);
  return itemSlug === slug || item.sys.id === slug;
});

if (!data) return new Response(null, { status: 404 });

// @ts-ignore
const resolvedSlug = data.fields.slug ?? slugify(data.fields.title);

if (slug === data.sys.id && slug !== resolvedSlug) {
  return Astro.redirect(`/${local}/gallery/${resolvedSlug}`, 301);
}

const breadcrumbsData = [
  { link: "/", title: String(ui[local].gallery.single.breadcrumbs[0]) },
  { link: "/gallery", title: String(ui[local].gallery.single.breadcrumbs[1]) },
  { link: "", title: String(data.fields.title) },
];

export const prerender = false;
Astro.response.headers.set('Cache-Control', 'public, max-age=0, s-maxage=3600, stale-while-revalidate=86400');
---

<Layout
  title={data.fields.title ? `${data.fields.title} | Vimec Valves Gallery` : "Product Gallery | Vimec Valves"}
  description={`View precision photos and details for ${data.fields.title} in the Vimec Valves gallery.`}
>
  <section
    class:list={[
      "wrapper flex md:mt-32 mt-28 flex-col gap-10 ",
      main_padding.y,
    ]}
  >
    <div class="flex flex-col gap-6">
      <Breadcrumbs data={breadcrumbsData} />
      <HeroSectionHeader
        title={data.fields.title + "\u00A0" + ui[local].gallery.single.photos}
      />
    </div>
    <ImagesGrid client:visible data={data} local={local!} server:defer>
      <Fallback slot="fallback" />
    </ImagesGrid>
  </section>
</Layout>
