---
import Layout from "@/components/layout/Layout.astro";
import main_padding from "@/styles/padding";
import HeroSectionHeader from "@/ui/HeroSectionHeader.astro";

import { getRelativeLocaleUrlList } from "astro:i18n";
import img from "@/assets/image/dummi/news.png";
import Link from "@/libs/helpers/Link.astro";
import { Image } from "astro:assets";
import { ui } from "@/i18n/ui";
import { contentfulClient } from "@/libs/content/contentful/data";
import type { TypeGallery } from "@/libs/content/contentful/entriesType";
import { slugify } from "@/libs/utils/slugify";

export const prerender = false;
Astro.response.headers.set('Cache-Control', 'public, max-age=0, s-maxage=3600, stale-while-revalidate=86400');
const locale = Astro.currentLocale as "en" | "it";

const data = await contentfulClient.getEntries<TypeGallery>({
  content_type: "gallery",
  include: 2,
  locale: locale,
});
---

<Layout
  title="Industrial Valve Gallery | High Performance Vimec Valves"
  description="View our gallery of precision-engineered sampling valves and industrial products."
>
  <section
    class:list={["wrapper mt-28 flex flex-col gap-10 md:mt-32", main_padding.y]}
  >
    <HeroSectionHeader
      title={ui[locale].gallery["hero-section"].title}
      content={ui[locale].gallery["hero-section"].content}
    />

    <div
      class="grid gap-x-6 gap-y-8 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4"
    >
      {
        data.items.map((item) => {
          // @ts-ignore
          const slug = item.fields.slug ?? slugify(item.fields.title);
          return (
          <Link
            href={`gallery/${encodeURIComponent(slug)}`}
            class="reveal-up group relative flex flex-col items-center justify-center overflow-hidden rounded-xl bg-[#F4F4F4] shadow-[0_2px_8px_rgba(0,0,0,0.07)] hover:shadow-[0_10px_28px_rgba(0,0,0,0.14)] hover:-translate-y-1 transition-all duration-300"
          >
            {/* Image with hover zoom */}
            <Image
              src={item?.fields?.images[0]?.fields?.file?.url}
              alt={
                item.fields.title ? item.fields.title + " gallery thumbnail" : "Gallery thumbnail"
              }
              width={400}
              height={220}
              transition:name={item.sys.id}
              class="aspect-video w-full object-cover transition-transform duration-400 ease-out group-hover:scale-105"
            />
            {/* Gradient overlay + title */}
            <div class="absolute inset-0 bg-gradient-to-t from-black/65 via-black/10 to-transparent rounded-xl pointer-events-none" />
            <h2 class="absolute bottom-0 left-0 w-full px-4 py-3 text-lg font-semibold text-white leading-snug drop-shadow-sm">
              {item.fields.title}
            </h2>
          </Link>
          );
        })
      }
    </div>
  </section>
</Layout>
