---
import HeroSection from "@/components/about-us/HeroSection.astro";
import OurHistory from "@/components/about-us/OurHistory.astro";
import GetInTouch from "@/components/home/GetInTouch.astro";
import Layout from "@/components/layout/Layout.astro";

import { getRelativeLocaleUrlList } from "astro:i18n";

Astro.response.headers.set('Cache-Control', 'public, max-age=0, s-maxage=3600, stale-while-revalidate=86400');

export const prerender = false;

export function getStaticPaths() {
  return [
    { params: { locale: 'en' } },
    { params: { locale: 'it' } },
  ];
}
---

<Layout
  title="Industrial Valve Manufacturer in UK | About Vimec Valves"
  description="Learn about Vimec Valves, our history, and our commitment to manufacturing the highest quality sampling and industrial valves."
>
  <HeroSection />
  <OurHistory />
  <GetInTouch />
</Layout>
