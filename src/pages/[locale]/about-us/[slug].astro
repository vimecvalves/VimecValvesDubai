---
import HeroSection from "@/components/about-us/department/HeroSection.astro";
import GetInTouch from "@/components/home/GetInTouch.astro";
import Layout from "@/components/layout/Layout.astro";
import { contentfulClient } from "@/libs/content/contentful/data";
import { slugify } from "@/libs/utils/slugify";
import type { TypeDepartmentAboutUs } from "@/libs/content/contentful/entriesType";

export const prerender = false;
Astro.response.headers.set('Cache-Control', 'public, max-age=0, s-maxage=3600, stale-while-revalidate=86400');

const { slug } = Astro.params;
const local = Astro.currentLocale as "en" | "it";

const otherLocal = local === "it" ? "en" : "it";

const [allDepartmentsRes, otherDepartmentsRes] = await Promise.all([
  contentfulClient.getEntries<TypeDepartmentAboutUs>({
    content_type: 'departmentAboutUs',
    locale: local,
    include: 2,
  }),
  contentfulClient.getEntries<TypeDepartmentAboutUs>({
    content_type: 'departmentAboutUs',
    locale: otherLocal,
    include: 2,
  })
]);

const getSlug = (item: any) => item.fields.slug ?? slugify(item.fields.title);

const allDepartments = allDepartmentsRes;
let data = allDepartments.items.find((item) => getSlug(item) === slug || item.sys.id === slug);
let alternateUrls: Record<string, string> = {};

if (!data) {
  const otherDataMatch = otherDepartmentsRes.items.find((item) => getSlug(item) === slug || item.sys.id === slug);
  if (otherDataMatch) {
    const currentLocData = allDepartments.items.find(i => i.sys.id === otherDataMatch.sys.id);
    if (currentLocData) return Astro.redirect(`/${local}/about-us/${getSlug(currentLocData)}`, 301);
  }
  return new Response(null, { status: 404 });
} else {
  const resolvedSlug = getSlug(data);
  if (slug === data.sys.id && slug !== resolvedSlug) {
    return Astro.redirect(`/${local}/about-us/${resolvedSlug}`, 301);
  }
  
  const otherLocData = otherDepartmentsRes.items.find(i => i.sys.id === data.sys.id);
  alternateUrls = {
    [local]: `/${local}/about-us/${resolvedSlug}`,
    [otherLocal]: `/${otherLocal}/about-us/${otherLocData ? getSlug(otherLocData) : resolvedSlug}`
  };
}
---

<Layout
  title={`${data.fields.title} | Vimec Valves`}
  description={`Learn more about the ${data.fields.title} department at Vimec Valves, committed to engineering and manufacturing high-quality industrial valves.`}
  alternateUrls={alternateUrls}
>
  <HeroSection data={data} />
  <GetInTouch />
</Layout>
