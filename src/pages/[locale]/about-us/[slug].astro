---
import HeroSection from "@/components/about-us/department/HeroSection.astro";
import GetInTouch from "@/components/home/GetInTouch.astro";
import Layout from "@/components/layout/Layout.astro";
import { contentfulClient } from "@/libs/content/contentful/data";
import { slugify } from "@/libs/utils/slugify";
import type { TypeDepartmentAboutUs } from "@/libs/content/contentful/entriesType";

export const prerender = false;
Astro.response.headers.set('Cache-Control', 'public, max-age=0, s-maxage=3600, stale-while-revalidate=86400');

const { slug } = Astro.params;
const local = Astro.currentLocale as "en" | "it";

const allDepartments = await contentfulClient.getEntries<TypeDepartmentAboutUs>({
  content_type: 'departmentAboutUs',
  locale: local,
  include: 2,
});

const data = allDepartments.items.find((item) => {
  // @ts-ignore
  const itemSlug = item.fields.slug ?? slugify(item.fields.title);
  return itemSlug === slug || item.sys.id === slug;
});

if (!data) return new Response(null, { status: 404 });

// @ts-ignore
const resolvedSlug = data.fields.slug ?? slugify(data.fields.title);

if (slug === data.sys.id && slug !== resolvedSlug) {
  return Astro.redirect(`/${local}/about-us/${resolvedSlug}`, 301);
}
---

<Layout
  title={`${data.fields.title} | Vimec Valves`}
  description={`Learn more about the ${data.fields.title} department at Vimec Valves, committed to engineering and manufacturing high-quality industrial valves.`}
>
  <HeroSection data={data} />
  <GetInTouch />
</Layout>
